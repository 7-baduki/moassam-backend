<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://www.hibernate.org/xsd/orm/mapping
                                     https://hibernate.org/xsd/orm/mapping/mapping-3.1.0.xsd">
  <access>FIELD</access>

  <entity class="com.moassam.user.domain.User">
    <table name="users">
      <unique-constraint name="uk_users_provider">
        <column-name>provider</column-name>
        <column-name>provider_id</column-name>
      </unique-constraint>
    </table>
    <attributes>
      <id name="id">
        <column name="id"/>
        <generated-value strategy="IDENTITY"/>
      </id>
      <basic name="provider">
        <column name="provider" nullable="false" length="20"/>
        <enumerated>STRING</enumerated>
      </basic>
      <basic name="providerId">
        <column name="provider_id" nullable="false"/>
      </basic>
      <basic name="email">
        <column name="email"/>
      </basic>
      <basic name="nickname">
        <column name="nickname" length="50"/>
      </basic>
      <basic name="role">
        <column name="role" nullable="false" length="20"/>
        <enumerated>STRING</enumerated>
      </basic>
      <basic name="profileImageUrl">
        <column name="profile_image_url" length="500"/>
      </basic>
      <basic name="deletedAt">
        <column name="deleted_at"/>
      </basic>
    </attributes>
  </entity>

  <entity class="com.moassam.auth.domain.RefreshToken">
    <table name="refresh_tokens">
      <unique-constraint name="uk_refresh_tokens_token">
        <column-name>token</column-name>
      </unique-constraint>
    </table>
    <attributes>
      <id name="id">
        <column name="id"/>
        <generated-value strategy="IDENTITY"/>
      </id>
      <basic name="userId">
        <column name="user_id" nullable="false"/>
      </basic>
      <basic name="token">
        <column name="token" nullable="false" length="512"/>
      </basic>
      <basic name="expiresAt">
        <column name="expires_at" nullable="false"/>
      </basic>
    </attributes>
  </entity>

  <entity class="com.moassam.post.domain.Post">
    <table name="posts"/>

    <attributes>
      <id name="id">
        <column name="id"/>
        <generated-value strategy="IDENTITY"/>
      </id>

      <basic name="userId">
        <column name="user_id" nullable="false"/>
      </basic>

      <basic name="title">
        <column name="title" nullable="false" length="200"/>
      </basic>

      <basic name="content">
        <column name="content" nullable="false"/>
      </basic>

      <basic name="category">
        <column name="category" nullable="false" length="20"/>
        <enumerated>STRING</enumerated>
      </basic>

      <basic name="age">
        <column name="age" length="20"/>
        <enumerated>STRING</enumerated>
      </basic>

      <basic name="resourceType">
        <column name="resource_type" length="30"/>
        <enumerated>STRING</enumerated>
      </basic>

      <basic name="headTag">
        <column name="head_tag" length="30"/>
        <enumerated>STRING</enumerated>
      </basic>

      <basic name="viewCount">
        <column name="view_count" nullable="false"/>
      </basic>

      <basic name="likeCount">
        <column name="like_count" nullable="false"/>
      </basic>

      <basic name="commentCount">
        <column name="comment_count" nullable="false"/>
      </basic>
    </attributes>
  </entity>

  <entity class="com.moassam.post.domain.PostFile">
    <table name="post_files"/>

    <attributes>
      <id name="id">
        <column name="id"/>
        <generated-value strategy="IDENTITY"/>
      </id>

      <basic name="postId">
        <column name="post_id" nullable="false"/>
      </basic>

      <basic name="originalName">
        <column name="original_name" nullable="false" length="255"/>
      </basic>

      <basic name="url">
        <column name="url" nullable="false" length="1000"/>
      </basic>

      <basic name="size">
        <column name="size" nullable="false"/>
      </basic>

      <basic name="fileType">
        <column name="file_type" nullable="false" length="20"/>
        <enumerated>STRING</enumerated>
      </basic>
    </attributes>
  </entity>

</entity-mappings>